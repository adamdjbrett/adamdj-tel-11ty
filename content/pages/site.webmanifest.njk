---
permalink: /site.webmanifest
eleventyExcludeFromCollections: true
layout: false
---
{
    "name": "{{ metadata.siteName or metadata.title }}",
    "short_name": "{{metadata.github_username}}",
    "icons": [
        {
            "src": "/img/favicon/android-icon-192x192.webp",
            "sizes": "192x192",
            "type": "image/webp"
        },
        {
            "src": "/img/favicon/apple-icon-180x180.webp",
            "sizes": "180x180",
            "type": "image/webp"
        }
    ],
    "theme_color": "#ffffff",
    "background_color": "#ffffff",
    "display": "standalone"
}
